{
  "name": "amber-chrome-extension",
  "displayName": "Amber",
  "description": "A Chrome extension that allows you to save and organize your favorite websites in a simple and intuitive way.",
  "version": "0.0.1",
  "private": true,
  "author": "Vittorio Scaperrotta",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">= 22.0.0"
  },
  "scripts": {
    "dev": "better-npm-run dev",
    "build": "better-npm-run build",
    "build:prepare": "node scripts/prepare.js",
    "build:web": "vite build",
    "lint": "eslint .",
    "preview": "better-npm-run preview",
    "clear": "rimraf --glob dist",
    "watch-build": "node scripts/watch-build.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "betterScripts": {
    "dev": {
      "command": "vite",
      "env": {
        "NODE_ENV": "development"
      }
    },
    "preview": {
      "command": "vite preview",
      "env": {
        "NODE_ENV": "development"
      }
    },
    "build": {
      "command": "run-s clear build:web build:prepare",
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "dependencies": {
    "@firebase/app": "^0.14.10",
    "@firebase/auth": "^1.12.2",
    "@types/chrome": "^0.0.299",
    "archiver": "^7.0.1",
    "better-npm-run": "^0.1.1",
    "cross-env": "^7.0.3",
    "d3": "^7.9.0",
    "firebase": "^12.11.0",
    "fs-extra": "^11.3.0",
    "lucide-react": "^1.7.0",
    "npm-run-all": "^4.1.5",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "sass": "^1.83.4",
    "storybook": "^10.3.3",
    "terser": "^5.37.0",
    "vite-plugin-static-copy": "^2.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@storybook/builder-vite": "^10.3.3",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "typescript": "^5",
    "vite": "^6.0.11"
  }
}
